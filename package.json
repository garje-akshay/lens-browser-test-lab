{
  "name": "browser-test-lab",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\"",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
